#!/bin/bash
###############################################################################
# config_callback —— 用户在「应用设置」保存后触发（含授权目录增删）
# 此时 fnOS 已更新 TRIM_DATA_ACCESSIBLE_PATHS 等环境变量。
# 我们重启服务，使新的书库根目录（roots 文件）立即生效。
###############################################################################

MAIN="$(dirname "$0")/main"

if [ -x "${MAIN}" ]; then
    "${MAIN}" stop 2>/dev/null
    "${MAIN}" start 2>/dev/null
fi

exit 0
